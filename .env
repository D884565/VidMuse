# ==================================================
# 应用基础配置
# ==================================================
# 运行环境: development / production / test
APP_ENV=development
# 服务监听地址
APP_HOST=0.0.0.0
# 服务监听端口
APP_PORT=8000

# ==================================================
# MySQL 数据库配置
# ==================================================
# 数据库地址
MYSQL_HOST=localhost
# 数据库端口
MYSQL_PORT=3306
# 数据库名称
MYSQL_DATABASE=aigc_video
# 数据库用户名
MYSQL_USER=aigc_user
# 数据库密码
MYSQL_PASSWORD=aigc_password
# 数据库root密码（Docker部署时使用）
MYSQL_ROOT_PASSWORD=root_password

# ==================================================
# MinIO 对象存储配置
# ==================================================
# MinIO服务地址
MINIO_ENDPOINT=localhost:9000
# MinIO访问密钥
MINIO_ACCESS_KEY=minioadmin
# MinIO安全密钥
MINIO_SECRET_KEY=minioadmin
# MinIO存储桶名称
MINIO_BUCKET_NAME=aigc-videos
# 是否使用HTTPS访问
MINIO_SECURE=true

# ==================================================
# ChromaDB 向量数据库配置
# ==================================================
# ChromaDB服务地址
CHROMADB_HOST=localhost
# ChromaDB服务端口（注意：Docker映射到宿主机是8001，容器内部是8000）
CHROMADB_PORT=8001
# 向量集合名称
CHROMADB_COLLECTION=video_embeddings
# 租户标识
CHROMADB_TENANT=default_tenant
# 数据库名称
CHROMADB_DATABASE=default_database

# ==================================================
# LLM API 配置（根据需要填写）
# ==================================================
# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here
# Anthropic API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# 火山引擎API Key
VOLCENGINE_API_KEY=ark-3a6a7711-6bc2-444d-9572-f9e1887a7aab-40a6c

# ==================================================
# Redis 配置（可选，Celery需要）
# ==================================================
# Redis地址
REDIS_HOST=localhost
# Redis端口
REDIS_PORT=6379
# Redis数据库
REDIS_DB=0
