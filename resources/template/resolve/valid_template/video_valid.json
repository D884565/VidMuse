{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VideoTemplateSchema",
  "type": "object",
  "required": ["基本信息", "片段索引列表"],
  "properties": {
    "基本信息": {
      "type": "object",
      "required": ["商品", "剧本", "模板", "摘要"],
      "properties": {
        "商品": { "type": "string" },
        "剧本": { "type": "string" },
        "模板": { "type": "string" },
        "摘要": { "type": "string" }
      },
      "additionalProperties": true
    },

    "片段索引列表": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["slice_id", "time_range_ms", "序号", "模板类型"],
        "properties": {
          "slice_id": { "type": "string", "pattern": "^s_\\d+$" },
          "time_range_ms": {
            "type": "array",
            "items": { "type": "integer", "minimum": 0 },
            "minItems": 2,
            "maxItems": 2
          },
          "序号": { "type": "integer", "minimum": 1 },
          "模板类型": {
            "type": "string",
            "enum": ["HOOK", "PAIN_POINT", "PRODUCT_SHOW", "TRUST_BUILD", "CTA", "REVERSE"]
          }
        },
        "additionalProperties": true
      }
    },

    "片段间关系": {
      "type": "object",
      "required": ["转场序列", "情绪曲线"],
      "properties": {
        "转场序列": { "type": "array", "items": { "type": "string" } },
        "情绪曲线": { "type": "array", "items": { "type": "string" } },
        "视觉节奏": { "type": "string" },
        "BGM节奏匹配": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}