{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SliceTemplateSchema",
  "type": "object",
  "required": ["片段模板"],
  "properties": {
    "片段模板": {
      "type": "object",
      "required": ["模板名称", "模板类型", "机制","总结"],
      "properties": {
        "模板名称": { "type": "string" },
        "模板类型": {
          "type": "string",
          "enum": ["HOOK", "PAIN_POINT", "PRODUCT_SHOW", "TRUST_BUILD", "CTA"]
        },
        "机制": { "type": "string" },
        "总结": { "type": "string" },

        "创作要素": {
          "type": "object",
          "required": ["画面", "动作", "台词", "运镜", "时长","视觉标签"],
          "properties": {
            "画面": { "type": "string" },
            "动作": { "type": "string" },
            "台词": { "type": "string" },
            "运镜": { "type": "string" },
            "时长": { "type": "string" },
            "情绪评分": {
              "type": ["string", "number"],
              "minimum": 0,
              "maximum": 1
            },
            "视觉标签": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": true
        },

        "关键帧时间戳": {
          "type": "array",
          "items": { "type": "number", "minimum": 0 }
        },

        "一致性": {
          "type": "object",
          "properties": {
            "商品是否出现": { "type": ["string", "boolean"] },
            "商品": { "type": "array", "items": { "type": "string" } },
            "置信度": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}