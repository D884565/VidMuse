{
  "name": "商品理解提示词",
  "description": "用于分析图文内容，输出商品的结构化信息",
  "template": "请分析以下图文内容，输出商品的结构化信息，严格按照JSON格式返回，不要有其他内容。\n需要包含以下字段：\n1. 商品基础信息：包含商品名称、商品类目预测、品牌信息、SKU_ID\n2. 目标人群：包含核心人群（数组）、消费心理（数组）、使用场景（数组）\n3. 卖点列表：数组，每个元素包含名称、描述、优先级、视频表现手法、口播参考\n4. 物理属性：包含通用属性（材质成分、季节等）、类目专属扩展字段（根据商品类目灵活添加）\n5. 价格与服务：包含原价、现价、促销策略、价格锚点、服务保障（数组）\n6. 视觉资产：包含商品主图、商品细节图（数组）、使用场景图（数组）、品牌VI色（数组）\n7. 竞争差异化：包含对比维度、独家优势（数组）\n8. 合规限制：包含禁用话术（数组）、必须声明（数组）\n\n如果信息不足，可以留空或生成合理的模拟值，但必须保证结构完整。",
  "output_schema": "product_valid.json",
  "output_structure": {
    "商品基础信息": {
      "商品名称": "商品名称",
      "商品类目预测": "商品类目",
      "品牌信息": "品牌名称",
      "SKU_ID": "SKU编号"
    },
    "目标人群": {
      "核心人群": ["25-35岁女性", "梨形身材", "职场新人"],
      "消费心理": ["追求性价比", "注重颜值", "社交分享欲强"],
      "使用场景": ["日常通勤", "周末约会", "拍照打卡"]
    },
    "卖点列表": [
      {
        "名称": "卖点名称",
        "描述": "卖点描述",
        "优先级": "P0",
        "视频表现手法": "视频中的表现方式",
        "口播参考": "口播参考话术"
      }
    ],
    "物理属性": {
      "通用属性": {
        "材质成分": "材质描述",
        "季节": "适用季节"
      },
      "类目专属扩展字段": {}
    },
    "价格与服务": {
      "原价": 299,
      "现价": 159,
      "促销策略": "促销策略描述",
      "价格锚点": "价格锚点描述",
      "服务保障": ["服务保障1", "服务保障2"]
    },
    "视觉资产": {
      "商品主图": "主图URL",
      "商品细节图": ["细节图URL"],
      "使用场景图": ["场景图URL"],
      "品牌VI色": ["#FF0000"]
    },
    "竞争差异化": {
      "对比维度": "对比维度描述",
      "独家优势": ["独家优势1", "独家优势2"]
    },
    "合规限制": {
      "禁用话术": ["禁用话术1", "禁用话术2"],
      "必须声明": ["必须声明1", "必须声明2"]
    }
  }
}
